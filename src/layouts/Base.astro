---
import '../styles/global.css';

export interface Props {
  titulo?: string;
  descripcion?: string;
}

const {
  titulo = 'Ángel Perdomo — Notas técnicas',
  descripcion = 'Artículos sobre ciberseguridad, redes e infraestructura.',
} = Astro.props;

const base = import.meta.env.BASE_URL.replace(/\/?$/, '/');
---

<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <title>{titulo}</title>
    <meta name="description" content={descripcion} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={titulo} />
    <meta property="og:description" content={descripcion} />

    <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
  </head>
  <body>
    <div class="wrap">
      <header class="site-header">
        <a href={base} class="brand">
          <span class="prompt">$</span>
          <span class="name">popi</span><span class="cursor"></span>
        </a>
        <p class="tagline">
          Ciberseguridad, redes e infraestructura. Notas de incidentes reales y
          threat intel accesible.
        </p>
        <nav>
          <a href={base}>~/articulos</a>
          <a href="https://www.linkedin.com/in/angelperdomo/" target="_blank" rel="noopener">linkedin</a>
          <a href={`${base}rss.xml`}>rss</a>
        </nav>
      </header>

      <main>
        <slot />
      </main>

      <footer class="site-footer">
        <span>© {new Date().getFullYear()} Ángel Perdomo · Minas, UY</span>
        <span>built with astro · hosted on gh-pages</span>
      </footer>
    </div>
  </body>
</html>
